{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "chunk_id",
    "summary",
    "decisions",
    "unresolved_candidate_ids",
    "notes"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "search"
    },
    "chunk_id": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "assistant_status",
          "assistant_action",
          "assistant_reason"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "assistant_status": {
            "type": "string",
            "minLength": 1
          },
          "assistant_action": {
            "type": "string",
            "minLength": 1
          },
          "assistant_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "unresolved_candidate_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
